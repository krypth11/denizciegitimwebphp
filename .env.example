# Required database settings. Do not commit real values.
DB_HOST=db.example.internal
DB_PORT=3306
DB_NAME=app_database
DB_USER=app_database_user
DB_PASSWORD=replace-with-secret-manager-value

# Required JWT settings. JWT_SECRET must be a random value of at least 32 characters.
JWT_SECRET=replace-with-strong-random-secret-from-secret-manager
JWT_ISSUER=https://admin.example.invalid
JWT_AUDIENCE=denizci-admin
JWT_EXPIRY_SECONDS=86400

# Required for anonymous guest-device quota hashing. Use an independent random value of at least 32 characters.
GUEST_DEVICE_HMAC_KEY=replace-with-strong-random-secret-from-secret-manager

# Authentication throttling.
AUTH_RATE_LIMIT_MAX_ATTEMPTS=8
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_BLOCK_SECONDS=900
PASSWORD_RESET_MAX_REQUESTS=3
PASSWORD_RESET_WINDOW_SECONDS=3600

# Optional mail settings; password must come from a secret manager in production.
SMTP_HOST=smtp.example.invalid
SMTP_PORT=587
SMTP_USERNAME=mailer@example.invalid
SMTP_PASSWORD=replace-with-secret-manager-value
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=no-reply@example.invalid
SMTP_FROM_NAME=Denizci Eğitim

# Optional RSS host allowlist. Comma-separated exact hostnames; empty disables RSS fetching.
NEWS_RSS_ALLOWED_HOSTS=news.example.invalid

# Required to grant RevenueCat Premium. Never use a public mobile SDK key here.
REVENUECAT_SECRET_API_KEY=replace-with-revenuecat-server-secret
REVENUECAT_PREMIUM_ENTITLEMENT_ID=premium
